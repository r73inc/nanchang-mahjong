# Copy this file to .env and fill in values for local development.
# .env is gitignored — never commit real secrets.
#
# After copying:
#   1. Run: docker compose up -d
#   2. Run: pnpm --filter @nanchang/api run setup:local
#   3. Paste the printed COGNITO_USER_POOL_ID and COGNITO_CLIENT_ID below.
#   4. Run: pnpm --filter @nanchang/api run seed:admin

# ── App ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT (change both secrets before any real deployment!) ─────
JWT_SECRET=dev-secret-change-in-prod
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod
JWT_REFRESH_EXPIRES_IN=30d

# ── AWS SDK routing (points to Docker containers in dev) ──────
AWS_REGION=ap-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ── DynamoDB Local (docker: mj-dynamodb) ──────────────────────
AWS_ENDPOINT_URL_DYNAMODB=http://localhost:8000
DYNAMODB_TABLE_NAME=nanchang_main

# ── MinIO / S3 (docker: mj-minio) ────────────────────────────
# forcePathStyle is enabled automatically when this var is set.
AWS_ENDPOINT_URL_S3=http://localhost:9000
S3_REPLAY_BUCKET=nanchang-replays
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Cognito Local (docker: mj-cognito) ───────────────────────
# These values are printed by: pnpm --filter @nanchang/api run setup:local
AWS_ENDPOINT_URL_COGNITO_IDP=http://localhost:9229
COGNITO_USER_POOL_ID=local_placeholder
COGNITO_CLIENT_ID=placeholder

# ── MailHog / SMTP (docker: mj-mailhog) ──────────────────────
# Captured emails are readable at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@nanchang.local

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX_PUBLIC=5
RATE_LIMIT_MAX_AUTHED=60

# ── Web Push / VAPID (optional — leave empty to disable) ──────
# Generate keys: pnpm --filter @nanchang/api exec npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:admin@nanchang.local
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
