  "learnOverviewTitle": "What is Nanchang Mahjong?",
  "learnOverviewBody": "A 4-player tile game from Nanchang, China. Players build hands from melds and pairs, racing to declare a winning hand. The defining feature is the Spirit Tile (精 Jīng) — a wildcard revealed fresh each round.",
  "learnOverviewPlayers": "4 Players",
  "learnOverviewTileCount": "136 Tiles",
  "learnOverviewRounds": "East + South Rounds",

  "learnTilesTitle": "Tile Types",
  "learnTilesSuitsTitle": "Suited Tiles",
  "learnTilesSuitsDesc": "Three suits — Characters (萬), Dots (筒), and Bamboo (条) — numbered 1 to 9, four copies each. That's 108 suited tiles.",
  "learnTilesHonorsTitle": "Honor Tiles",
  "learnTilesHonorsDesc": "Four Winds (East, South, West, North) and three Dragons (Red 中, Green 發, White 白) — four copies each. Uniquely in Nanchang, three different Winds or all three Dragons can form a Chow sequence.",
  "learnTilesNoFlowers": "No flower or season tiles are used.",

  "learnSpiritTitle": "Spirit Tiles (精牌)",
  "learnSpiritBody": "After dealing, the dealer rolls two dice to find the Indicator Tile in the wall. The Indicator itself is the Primary Spirit; the next tile in rank becomes the Secondary Spirit.",
  "learnSpiritPrimaryLabel": "Primary Spirit (正精)",
  "learnSpiritSecondaryLabel": "Secondary Spirit (副精)",
  "learnSpiritWildcard": "A Spirit Tile can substitute for any tile in a Chow, Pung, or Pair — but once discarded it reverts to its face value.",
  "learnSpiritPayouts": "At the end of every hand each player pays others based on the Jing tiles in their hand. Holding 5+ Spirit points earns a multiplier bonus.",
  "learnSpiritExplosiveLabel": "Explosive Spirit (冲关)",
  "learnSpiritExplosiveDesc": "5 pts → ×2 · 6 pts → ×3 · 7 pts → ×4",

  "learnGameplayTitle": "How to Play",
  "learnGameplayBody": "Play proceeds counter-clockwise. On your turn: draw a tile from the wall, optionally form or upgrade melds, then discard one tile face-up.",
  "learnGameplayPriority": "Claim priority: Win > Kong/Pung > Chow",
  "learnGameplayChowTitle": "Chow (吃) — Sequence",
  "learnGameplayChowDesc": "Claim a discard from the player to your left to complete a run of 3 in the same suit. In Nanchang, three different Winds or all three Dragons also form valid sequences.",
  "learnGameplayHonorChowNote": "Nanchang honor sequence",
  "learnGameplayPungTitle": "Pung (碰) — Triplet",
  "learnGameplayPungDesc": "Claim any player's discard to complete 3 of a kind. Out-of-turn — you skip ahead in the rotation.",
  "learnGameplayKongTitle": "Kong (杠) — Quad",
  "learnGameplayKongDesc": "Form 4 of a kind (exposed from a discard/pung, or concealed from your own draw). Draw one tile from the dead wall immediately. All players pay you an instant payout.",

  "learnHandsTitle": "Winning Hands",
  "learnHandsStandardTitle": "Standard Hand",
  "learnHandsStandardDesc": "4 melds (Chow, Pung, or Kong) plus 1 pair. The most common winning shape.",
  "learnHandsSevenPairsTitle": "Small Seven Pairs (小七对)",
  "learnHandsSevenPairsDesc": "Exactly 7 pairs. Must be fully concealed. ×2 multiplier.",
  "learnHandsBigSevenPairsTitle": "All Triplets (大七对)",
  "learnHandsBigSevenPairsDesc": "4 triplets or Kongs plus 1 pair. ×2 multiplier.",
  "learnHandsThirteenTitle": "Thirteen Misfits (十三烂)",
  "learnHandsThirteenDesc": "All tiles of the same suit at intervals greater than 2 (e.g. 1, 4, 7) plus unique honors. Must be fully concealed. ×2 multiplier.",
  "learnHandsSevenStarTitle": "Seven Star Thirteen Misfits (七星十三烂)",
  "learnHandsSevenStarDesc": "A Thirteen Misfits hand that includes all 7 unique honor tiles. Extremely rare. ×4 multiplier.",

  "learnScoringTitle": "Scoring",
  "learnScoringBase": "Base Points: 1 × Multipliers",
  "learnScoringDiscard": "Discard win: the discarder pays ×2; other players each pay ×1.",
  "learnScoringSelfdraw": "Self-draw: all three other players each pay ×2.",
  "learnScoringDealer": "Dealer: every amount the dealer wins or loses is doubled (×2).",
  "learnScoringKong": "Exposed Kong: 1 pt from each player instantly. Concealed Kong: 2 pts from each.",
  "learnScoringGerman": "German (德国): win without using any Spirit as a wildcard — earn (base ×2) + 5 pts bonus.",

  "lastDiscardLabel": "Last"
}
